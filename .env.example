# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Service identity ───────────────────────────────────────────────────────────
SERVICE_NAME=infermesh
SERVICE_VERSION=0.1.0

# ─── HTTP server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
# Milliseconds to wait for in-flight connections to drain on SIGINT/SIGTERM
SHUTDOWN_TIMEOUT_MS=10000
# Maximum request body size in bytes (default 1 MiB = 1048576)
BODY_LIMIT_BYTES=1048576

# ─── Logging ───────────────────────────────────────────────────────────────────
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Human-readable pino-pretty output (defaults true in development, false in production).
# Explicitly set false to see raw JSON locally, or true in prod for debugging.
# LOG_PRETTY=true

# ─── Auth (placeholder — not yet implemented) ──────────────────────────────────
AUTH_ENABLED=false
# Required when AUTH_ENABLED=true. Must be >= 32 characters in production.
# JWT_SECRET=change-me-in-production-minimum-32-characters

# ─── Feature flags ─────────────────────────────────────────────────────────────
# Enable incrementally as each module is implemented.
FEATURE_STREAMING=false
FEATURE_METRICS=false
FEATURE_SIMULATION=false
